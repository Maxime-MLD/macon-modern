---
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__info reveal reveal--left">
        <span class="eyebrow">Contact</span>
        <h2>Parlons de votre projet.</h2>
        <p class="lead">
          Décrivez-nous votre chantier : nous revenons vers vous sous 48 h avec un premier échange et un devis gratuit.
        </p>
        <div class="cinfo">
          <a href="tel:+33123456789">
            <span class="ic">
              <svg viewBox="0 0 24 24">
                <path d="M5 4h4l2 5-3 2a12 12 0 005 5l2-3 5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/>
              </svg>
            </span>
            <span>
              <span class="k">Téléphone</span><br />
              <span class="v">01 23 45 67 89</span>
            </span>
          </a>
          <a href="mailto:contact@maconmodern.fr">
            <span class="ic">
              <svg viewBox="0 0 24 24">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
            </span>
            <span>
              <span class="k">E-mail</span><br />
              <span class="v">contact@maconmodern.fr</span>
            </span>
          </a>
          <div>
            <span class="ic">
              <svg viewBox="0 0 24 24">
                <path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/>
                <circle cx="12" cy="10" r="2.5"/>
              </svg>
            </span>
            <span>
              <span class="k">Atelier</span><br />
              <span class="v">12 rue des Bâtisseurs, 42300 Roanne</span>
            </span>
          </div>
          <div>
            <span class="ic">
              <svg viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 7v5l3 2"/>
              </svg>
            </span>
            <span>
              <span class="k">Horaires</span><br />
              <span class="v">Lun–Ven · 8 h – 18 h</span>
            </span>
          </div>
        </div>
      </div>

      <form class="form reveal reveal--right" id="contact-form" novalidate>
        <div class="form__row">
          <div class="field">
            <label for="nom">Nom complet</label>
            <input id="nom" name="nom" type="text" placeholder="Jean Dupont" required />
          </div>
          <div class="field">
            <label for="tel">Téléphone</label>
            <input id="tel" name="tel" type="tel" placeholder="06 12 34 56 78" required />
          </div>
        </div>
        <div class="field">
          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" placeholder="jean.dupont@email.fr" required />
        </div>
        <div class="field">
          <label for="type">Type de projet</label>
          <select id="type" name="type">
            <option>Construction de maison neuve</option>
            <option>Rénovation / réhabilitation</option>
            <option>Piscine &amp; terrasse</option>
            <option>Mur / muret extérieur</option>
            <option>Gros œuvre</option>
            <option>Petit œuvre &amp; finitions</option>
            <option>Autre</option>
          </select>
        </div>
        <div class="field">
          <label for="msg">Votre projet</label>
          <textarea id="msg" name="msg" placeholder="Décrivez votre projet, la surface, la localisation, le délai souhaité…"></textarea>
        </div>
        <div class="form__submit">
          <button type="submit" class="btn btn--accent">Envoyer ma demande <span class="arr">→</span></button>
          <span class="form__note">Réponse sous 48 h · Devis gratuit et sans engagement</span>
          <span class="form__ok">✓ Merci ! Nous vous recontactons très vite.</span>
        </div>
      </form>
    </div>
  </div>
</section>
